# Sky Dodger — environment variables
# Copy to `.env.local` for development; provision the same set on Vercel.

# ── Database ─────────────────────────────────────────────────────────
# Vercel Postgres auto-injects POSTGRES_PRISMA_URL (pooled, pgbouncer)
# and POSTGRES_URL_NON_POOLING (direct, used by Prisma migrate).
# Locally, point both at the same database (or a docker-postgres URL).
DATABASE_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# ── NextAuth v5 (Google OAuth) ───────────────────────────────────────
# v5-native names. (Legacy NEXTAUTH_* / GOOGLE_* still readable for
# back-compat, but standardize on these.)
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Google AdSense ───────────────────────────────────────────────────
# Public client + one slot ID per ad placement. Leave blank in dev to
# render placeholder boxes.
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_ADSENSE_SLOT_LEADERBOARD=
NEXT_PUBLIC_ADSENSE_SLOT_RECTANGLE=
NEXT_PUBLIC_ADSENSE_SLOT_SKYSCRAPER=
NEXT_PUBLIC_ADSENSE_SLOT_NATIVE=
NEXT_PUBLIC_ADSENSE_SLOT_INTERSTITIAL=
NEXT_PUBLIC_ADSENSE_SLOT_BANNER_MOBILE=
